PORT=5000
DATABASE_URL=postgres://username:password@localhost:5432/greenmarket
JWT_SECRET=your_jwt_secret

# Gemini AI for admin AI Insights
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# VNPay (Sandbox/Test)
# You can use either the VNPAY_* keys below (recommended)
# or keys in VNPay style (vnp_TmnCode, vnp_HashSecret, vnp_Url, vnp_ReturnUrl).
VNPAY_TMN_CODE=your_vnp_tmn_code
VNPAY_HASH_SECRET=your_vnp_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-backend-domain/api/payment/vnpay-return

# Frontend redirect after VNPay return
FRONTEND_URL=http://localhost:5173
FRONTEND_PAYMENT_RESULT_PATH=/payment-result
