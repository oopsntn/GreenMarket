PORT=5000
IP=localhost
DATABASE_URL=postgres://username:password@localhost:5432/greenmarket
JWT_SECRET=your_jwt_secret

# VNPay (Sandbox/Test)
VNPAY_TMN_CODE=your_vnp_tmn_code
VNPAY_HASH_SECRET=your_vnp_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:5000/api/payment/vnpay-ipn

# Frontend redirect after VNPay return
FRONTEND_URL=http://localhost:5173
FRONTEND_PAYMENT_RESULT_PATH=/payment-result

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
